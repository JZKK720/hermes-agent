# Auto-generated files — collapse diffs and exclude from language stats
web/package-lock.json linguist-generated=true

# Shell scripts must keep LF line endings on all platforms (CRLF breaks
# shebang resolution inside Linux containers on Windows checkouts)
*.sh text eol=lf
docker/entrypoint.sh text eol=lf
docker/deploy.sh text eol=lf
docker/start-all.sh text eol=lf
